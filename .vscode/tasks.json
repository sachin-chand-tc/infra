{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Deploy: Backend (Cloud Run)",
      "type": "shell",
      "command": "./deploy-backend.sh",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "GCP_PROJECT_ID": "starkindustries-og"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Deploy: Planner Frontend",
      "type": "shell",
      "command": "./deploy-frontend.sh",
      "args": [
        "--site",
        "planner",
        "--redeploy"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "GCP_PROJECT_ID": "starkindustries-og"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Deploy: Sachins Frontend",
      "type": "shell",
      "command": "./deploy-frontend.sh",
      "args": [
        "--site",
        "sachins",
        "--redeploy"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "GCP_PROJECT_ID": "starkindustries-og"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Deploy: All (Backend + Planner + Sachins)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "./deploy-backend.sh && ./deploy-frontend.sh --site planner --redeploy && ./deploy-frontend.sh --site sachins --redeploy"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "GCP_PROJECT_ID": "starkindustries-og"
        }
      },
      "problemMatcher": []
    }
  ]
}
